{
  "name": "auth-flow",
  "private": true,
  "workspaces": [
    "packages/auth-flow",
    "packages/auth-callback",
    "packages/auth-login",
    "packages/auth-logout",
    "packages/workers/*"
  ],
  "scripts": {
    "fmt": "prettier -w .",
    "build:auth-flow": "node scripts/build-auth-flow.mjs",
    "test": "node --experimental-default-type=module --test tests/**/*.test.mjs",
    "deploy:cvr": "cd packages/workers/cvr-worker && wrangler deploy",
    "deploy:outseta": "cd packages/workers/outseta-plan-worker && wrangler deploy",
    "deploy:workers": "npm run deploy:cvr && npm run deploy:outseta"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "prettier": "^3.0.0",
    "wrangler": "^4.76.0"
  }
}
